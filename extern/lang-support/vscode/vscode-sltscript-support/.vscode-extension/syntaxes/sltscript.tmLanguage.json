{
  "name": "SLTScript",
  "scopeName": "source.sltscript",
  "fileTypes": ["sltscript"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#interpolated-strings"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#labels"
    },
    {
      "include": "#variable-scopes"
    },
    {
      "include": "#result-variable"
    },
    {
      "include": "#variables"
    },
    {
      "include": "#control-keywords"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#numbers"
    }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.semicolon.sltscript",
      "match": ";.*$"
    },
    "strings": {
      "name": "string.quoted.double.sltscript",
      "begin": "(?<!\\$)\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.sltscript",
          "match": "\"\""
        }
      ]
    },
    "interpolated-strings": {
      "name": "string.quoted.double.interpolated.sltscript",
      "begin": "\\$\"",
      "end": "\"",
      "beginCaptures": {
        "0": {
          "name": "string.quoted.double.interpolated.begin.sltscript"
        }
      },
      "endCaptures": {
        "0": {
          "name": "string.quoted.double.interpolated.end.sltscript"
        }
      },
      "patterns": [
        {
          "name": "variable.other.interpolated.sltscript",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.variable.begin.sltscript"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.variable.end.sltscript"
            }
          },
          "patterns": [
            {
              "include": "#variable-scopes"
            },
            {
              "include": "#variables"
            }
          ]
        },
        {
          "name": "constant.character.escape.sltscript",
          "match": "\"\""
        }
      ]
    },
    "labels": {
      "name": "entity.name.label.sltscript",
      "match": "\\[[^\\]]*\\]"
    },
    "variable-scopes": {
      "patterns": [
        {
          "name": "variable.other.global.sltscript",
          "match": "\\$(?i:global)\\.[a-zA-Z0-9_][a-zA-Z0-9_.]*",
          "captures": {
            "0": {
              "patterns": [
                {
                  "name": "support.type.scope.sltscript",
                  "match": "\\$(?i:global)\\."
                }
              ]
            }
          }
        },
        {
          "name": "variable.other.target.sltscript",
          "match": "\\$(?i:target)\\.(<[a-zA-Z0-9_][a-zA-Z0-9_.]*>)?[a-zA-Z0-9_][a-zA-Z0-9_.]*",
          "captures": {
            "0": {
              "patterns": [
                {
                  "name": "support.type.scope.sltscript",
                  "match": "\\$(?i:target)\\."
                }
              ]
            }
          }
        },
        {
          "name": "variable.other.thread.sltscript",
          "match": "\\$(?i:thread)\\.[a-zA-Z0-9_][a-zA-Z0-9_.]*",
          "captures": {
            "0": {
              "patterns": [
                {
                  "name": "support.type.scope.sltscript",
                  "match": "\\$(?i:thread)\\."
                }
              ]
            }
          }
        },
        {
          "name": "variable.other.system.sltscript",
          "match": "\\$(?i:system)\\.[a-zA-Z0-9_][a-zA-Z0-9_.]*",
          "captures": {
            "0": {
              "patterns": [
                {
                  "name": "support.type.scope.sltscript",
                  "match": "\\$(?i:system)\\."
                }
              ]
            }
          }
        },
        {
          "name": "variable.other.system.sltscript",
          "match": "\\$(?i:system)\\.[a-zA-Z0-9_][a-zA-Z0-9_.]*",
          "captures": {
            "0": {
              "patterns": [
                {
                  "name": "support.type.scope.sltscript",
                  "match": "\\$(?i:request)\\."
                }
              ]
            }
          }
        },
        {
          "name": "variable.other.local.sltscript",
          "match": "\\$(?i:local)\\.[a-zA-Z0-9_][a-zA-Z0-9_.]*",
          "captures": {
            "0": {
              "patterns": [
                {
                  "name": "support.type.scope.sltscript",
                  "match": "\\$(?i:local)\\."
                }
              ]
            }
          }
        }
      ]
    },
    "result-variable": {
      "name": "variable.language.result.sltscript",
      "match": "\\$\\$"
    },
    "variables": {
      "name": "variable.other.sltscript",
      "match": "\\$[a-zA-Z0-9_][a-zA-Z0-9_.]*"
    },
    "control-keywords": {
      "name": "keyword.control.sltscript",
      "match": "\\b(?i:if|elseif|else|endif|while|endwhile|goto|gosub|call|set|inc|return|beginsub|endsub|callarg|cat|resultfrom|true|false|none|mapunset|mapcopy|mapclear|maphaskey|mapkeys|listadd|listcount|listclear|listresize|listslice|string|bool|int|float|Form|label|listjoin|typeid|typename)\\b"
    },
    "functions": {
      "patterns": [
        {
          "name": "support.function.sltscript",
          "match": "\\b(?i:actor_advskill|actor_body|actor_display_name|actor_doaction|actor_doconsumer|actor_dofunction|actor_dogetter|actor_getfactionrank|actor_getgender|actor_getrelation|actor_getscale|actor_haskeyword|actor_haslos|actor_incskill|actor_infaction|actor_isaffectedby|actor_isguard|actor_isplayer|actor_isvalid|actor_iswearing|actor_lochaskeyword|actor_modcrimegold|actor_name|actor_playanim|actor_qnnu|actor_race|actor_race_type|actor_removefaction|actor_say|actor_sendmodevent|actor_setalpha|actor_setfactionrank|actor_setrelation|actor_setscale|actor_state|actor_submerged_level|actor_wornhaskeyword|actor_worninslot|actorbase_doconsumer|actorbase_dofunction|actorbase_dogetter|apply_overlay|armor_doconsumer|armor_dofunction|armor_dogetter|armor_getmaskforslot|av_damage|av_get|av_getbase|av_getmax|av_getpercentage|av_mod|av_restore|av_set|changeoverlay_transparency|console|dd_unlockall|dd_unlockslot|deb_msg|df_resetall|df_setdebt|form_addkeyword|form_doaction|form_doconsumer|form_dofunction|form_dogetter|form_getbyid|form_removekeyword|game_doaction|game_doconsumer|game_dofunction|game_dogetter|getoverlay_slot|global_getvalue|global_setvalue|globalvariable_doconsumer|globalvariable_dofunction|globalvariable_dogetter|ism_applyfade|ism_removefade|item_add|item_addex|item_adduse|item_equip|item_equipex|item_getcount|item_remove|item_unequipex|json_getvalue|json_save|json_setvalue|jsonutil|keyword_get|math|mfg_getphonememodifier|mfg_reset|mfg_setphonememodifier|msg_console|msg_notify|nff_getfollowers|nio_addnodeoverride_bool|nio_addnodeoverride_float|nio_addnodeoverride_int|nio_addnodeoverride_string|nio_addnodeoverride_textureset|nio_clearbodymorph|nio_get_morphkeys|nio_get_morphnames|nio_getbodymorph|nio_getnodeoverride_bool|nio_getnodeoverride_float|nio_getnodeoverride_int|nio_getnodeoverride_string|nio_getnodeoverride_textureset|nio_hasbodymorph|nio_hasnodeoverride|nio_setbodymorph|nio_updatemodelweight|objectreference_doaction|objectreference_doconsumer|objectreference_dofunction|objectreference_dogetter|osla_get_actor_days_since_last_orgasm|osla_get_arousal|osla_get_arousal_multiplier|osla_get_exposure|osla_modify_arousal|osla_modify_arousal_multiplier|osla_set_arousal|osla_set_arousal_multiplier|ostim_actorcount|ostim_animname|ostim_climax|ostim_findaction|ostim_getexcitement|ostim_getexcitementmultiplier|ostim_getrndactor|ostim_getsceneid|ostim_getthreadid|ostim_hasaction|ostim_isclimaxstalled|ostim_isin|ostim_isinslot|ostim_modifyexcitement|ostim_permitclimax|ostim_quickstart|ostim_setexcitement|ostim_setexcitementmultiplier|ostim_stallclimax|ostim_waitforend|ostim_waitforkbd|param_overlay|perk_add|perk_addpoints|perk_remove|quest_doaction|quest_doconsumer|quest_dofunction|quest_dogetter|remove_overlay|rnd_float|rnd_int|rnd_list|sl_add_cum|sl_adjustenjoyment|sl_advance|sl_allow_actor|sl_animname|sl_clear_cum|sl_count_cum|sl_disableorgasm|sl_endthread|sl_find_available_partners|sl_forbid_actor|sl_get_skill|sl_get_statistic|sl_getapi|sl_getprop|sl_getrndactor|sl_getversion|sl_getversionstring|sl_hastag|sl_is_forbidden|sl_is_valid_actor|sl_isactive|sl_isin|sl_isinslot|sl_isready|sl_orgasm|sl_startsex|sl_validate_actor|sl_waitforkbd|sla_get_actor_days_since_last_orgasm|sla_get_arousal|sla_get_exposure|sla_get_version|sla_send_exposure_event|sla_set_exposure|sla_update_exposure|slif_get_gender|slif_get_incrvalue|slif_get_maxvalue|slif_get_minvalue|slif_get_multvalue|slif_get_value|slif_get_version|slif_get_versionstring|slif_hide_node|slif_inflate|slif_is_inmaintenance|slif_is_installed|slif_is_node_hidden|slif_is_updating|slif_is_working|slif_register_actor|slif_reset_actor|slif_set_default_values|slif_show_node|slif_unregister_actor|slif_update_actor|sls_add_magic_curse|sls_block_license_purchase|sls_do_female_pain_sound|sls_do_hit_sound|sls_do_trauma_hit_sound|sls_evict_from_home|sls_get_creature_corruption|sls_get_cum_stuffed_factor|sls_get_load_fullness|sls_get_load_size|sls_get_load_size_actual|sls_get_load_tier|sls_get_skooma_junkie_level|sls_increase_ground_time|sls_is_drugged|sls_is_enjoying_cum|sls_is_high_on_lactacid|sls_is_high_on_skooma|sls_is_high_on_skooma_whore_drugs|sls_remove_magic_curse|sls_revoke_license|sls_send_to_kennel|sls_swallow_cum|sls_unevict_from_home|slso_bonus_enjoyment|snd_play|snd_setvolume|snd_stop|spell_add|spell_cast|spell_dcsa|spell_dispel|spell_remove|storageutil|tng_can_modify_actor|tng_get_actor_size|tng_set_actor_size|toh_elapsed_time|topicinfo_getresponsetext|uilib_showlist|uilib_shownotification|uilib_shownotificationicon|uilib_showtextinput|util_game|util_getgametime|util_getrandomactor|util_getrealtime|util_getrndactor|util_scan_cell_npcs|util_sendevent|util_sendmodevent|util_wait|util_waitforend|util_waitforkbd|weapon_doconsumer|weapon_dogetter|weather_state)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.sltscript",
          "match": "(==|!=|>=|<=|>|<|&&|\\|\\|)"
        },
        {
          "name": "keyword.operator.assignment.sltscript",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.sltscript",
          "match": "(\\+|-|\\*|/)"
        },
        {
          "name": "keyword.operator.string.sltscript",
          "match": "(&=|&!=|&)"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.sltscript",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.float.sltscript",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.sltscript",
          "match": "\\b\\d+\\b"
        }
      ]
    }
  }
}