{
    "comment_section" : [
        ["# this is an attributes file for an SLT extension"],
        ["# it will also contain this structure, letting SLT know what attributes to track"],
        ["# this is a comment because it starts with an octothorpe(#)"],
        ["# otherwise this file has to be proper json"],
        ["# it is divided into a 'triggers' block and a 'settings' block"],
        ["# the blocks are otherwise the same, following the same naming convention"]
    ],
    "trigger_attributes" : [
        ["# this section is just a simple list of attributes"],
        ["# one per row, yes"],
        ["event",               "triggerattribute_event"],
        ["chance",              "triggerattribute_chance"],
        ["daytime",             "triggerattribute_daytime"],
        ["deeplocation",        "triggerattribute_deeplocation"],
        ["is_armed",            "triggerattribute_is_armed"],
        ["is_clothed",          "triggerattribute_is_clothed"],
        ["is_weapon_drawn",     "triggerattribute_is_weapon_drawn"],
        ["do_1",                "triggerattribute_do_1"],
        ["do_2",                "triggerattribute_do_2"],
        ["do_3",                "triggerattribute_do_3"],
        ["do_4",                "triggerattribute_do_4"],
        ["asf_response",        "triggerattribute_asf_response"],
        ["asf_consensual",      "triggerattribute_asf_consensual"],
        ["asf_potential_orgy",  "triggerattribute_asf_potential_orgy"],
        ["asf_sex",             "triggerattribute_asf_sex"]
    ],
    "triggerattribute_event" : [
        ["# here is where you define aspects of the attribute"],
        ["type", "int"],
        ["widget", "menu", "$SLT_LBL_CORE_EVENT", "0", "$SLT_OPT_SELECT_AN_EVENT", "$SLT_OPT_ASF_AUTONOMOUS_SEX_FRAMEWORK"],
        ["info", "$SLT_INFO_CORE_EVENT"]
    ],
    "triggerattribute_chance" : [
        ["type", "float", "100.0"],
        ["widget", "slider", "$SLT_LBL_CORE_CHANCE", "0.0", "100.0", "1.0", "{0}"],
        ["info", "$SLT_INFO_CORE_CHANCE"]
    ],
    "triggerattribute_daytime" : [
        ["type", "int"],
        ["widget", "menu", "$SLT_LBL_CORE_DAYTIME", "0", "$SLT_OPT_ANY", "$SLT_OPT_DAY", "$SLT_OPT_NIGHT"],
        ["info", "$SLT_INFO_CORE_DAYTIME"]
    ],
    "triggerattribute_deeplocation": [
        ["type", "int"],
        ["widget", "menu", "$SLT_LBL_CORE_LOCATION", "0", "$SLT_OPT_ANY", "$SLT_OPT_INSIDE", "$SLT_OPT_OUTSIDE", "$SLT_OPT_SAFE_HOME_JAIL_INN", "$SLT_OPT_CITY_TOWN", "$SLT_OPT_WILDERNESS", "$SLT_OPT_DUNGEON", "$SLT_OPT_PLAYER_HOME", "$SLT_OPT_JAIL", "$SLT_OPT_DUNGEON_KEYWORD", "$SLT_OPT_CAVE", "$SLT_OPT_DWELLING", "$SLT_OPT_CITY", "$SLT_OPT_TOWN", "$SLT_OPT_HABITATION", "$SLT_OPT_DRAUGR_CRYPT", "$SLT_OPT_DRAGON_PRIEST_LAIR", "$SLT_OPT_BANDIT_CAMP", "$SLT_OPT_FALMER_HIVE", "$SLT_OPT_VAMPIRE_LAIR", "$SLT_OPT_DWEMER_RUINS", "$SLT_OPT_MILITARY_FORT", "$SLT_OPT_MINE", "$SLT_OPT_INN", "$SLT_OPT_HOLD"],
        ["info", "$SLT_INFO_CORE_LOCATION"]
    ],
    "triggerattribute_is_armed" : [
        ["type", "int"],
        ["widget", "menu", "$SLT_LBL_CORE_IS_WEAPON_SPELL_EQUIPPED", "0", "$SLT_OPT_ANY", "$SLT_OPT_EQUIPPED_IN_EITHER_HAND", "$SLT_OPT_NOT_EQUIPPED_IN_EITHER_HAND", "$SLT_OPT_NOT_EQUIPPED_IN_MAIN_HAND"],
        ["info", "$SLT_INFO_CORE_IS_WEAPON_SPELL_EQUIPPED"]
    ],
    "triggerattribute_is_clothed" : [
        ["type", "int"],
        ["widget", "menu", "$SLT_LBL_CORE_IS_ARMOR_CLOTHING_EQUIPPED", "0", "$SLT_OPT_ANY", "$SLT_OPT_EQUIPPED_IN_BODY_SLOT", "$SLT_OPT_NOT_EQUIPPED_IN_BODY_SLOT", "$SLT_OPT_NOT_EQUIPPED_OR_DEVIOUS"],
        ["info", "$SLT_INFO_CORE_IS_ARMOR_CLOTHING_EQUIPPED"]
    ],
    "triggerattribute_is_weapon_drawn": [
        ["type", "int"],
        ["widget", "menu", "$SLT_LBL_CORE_IS_WEAPON_SPELL_DRAWN", "0", "$SLT_OPT_ANY", "$SLT_OPT_WEAPON_SPELL_IS_DRAWN", "$SLT_OPT_WEAPON_SPELL_IS_NOT_DRAWN"],
        ["info", "$SLT_INFO_CORE_IS_WEAPON_SPELL_DRAWN"]
    ],
    "triggerattribute_do_1" : [
        ["type", "string"],
        ["widget", "command", "$SLT_LBL_CORE_SCRIPT_1"],
        ["info", "$SLT_INFO_CORE_SCRIPT_1"]
    ],
    "triggerattribute_do_2" : [
        ["type", "string"],
        ["widget", "command", "$SLT_LBL_CORE_SCRIPT_2"],
        ["info", "$SLT_INFO_CORE_SCRIPT_2"]
    ],
    "triggerattribute_do_3" : [
        ["type", "string"],
        ["widget", "command", "$SLT_LBL_CORE_SCRIPT_3"],
        ["info", "$SLT_INFO_CORE_SCRIPT_3"]
    ],
    "triggerattribute_do_4" : [
        ["type", "string"],
        ["widget", "command", "$SLT_LBL_CORE_SCRIPT_4"],
        ["info", "$SLT_INFO_CORE_SCRIPT_4"]
    ],
    "triggerattribute_asf_response" : [
        ["type", "int"],
        ["widget", "menu", "$SLT_LBL_ADULT_GENERAL_PLAYER_RESPONSE", "0", "$SLT_OPT_ANY", "$SLT_OPT_ACCEPT", "$SLT_OPT_ACQUIESCE", "$SLT_OPT_DECLINE", "$SLT_OPT_REFUSE", "$SLT_OPT_CANCEL"],
        ["info", "$SLT_INFO_ADULT_GENERAL_PLAYER_RESPONSE"]
    ],
    "triggerattribute_asf_consensual" : [
        ["type", "int"],
        ["widget", "menu", "$SLT_LBL_ADULT_GENERAL_PLAYER_CONSENTS", "0", "$SLT_OPT_ANY", "$SLT_OPT_ACCEPT_ACQUIESCE", "$SLT_OPT_DECLINE_REFUSE_CANCEL", "$SLT_OPT_DECLINE_REFUSE"],
        ["info", "$SLT_INFO_ADULT_GENERAL_PLAYER_CONSENTS"]
    ],
    "triggerattribute_asf_potential_orgy" : [
        ["type", "int"],
        ["widget", "menu", "$SLT_LBL_ADULT_GENERAL_POTENTIAL_ORGY", "0", "$SLT_OPT_ANY", "$SLT_OPT_IS_POTENTIAL_ORGY", "$SLT_OPT_IS_NOT_POTENTIAL_ORGY"],
        ["info", "$SLT_INFO_ADULT_GENERAL_POTENTIAL_ORGY"]
    ],
    "triggerattribute_asf_sex" : [
        ["type", "int"],
        ["widget", "menu", "$SLT_LBL_ADULT_GENERAL_ASF_REQUESTOR_SEX", "0", "$SLT_OPT_ANY", "$SLT_OPT_MALE", "$SLT_OPT_FEMALE"],
        ["info", "$SLT_INFO_ADULT_GENERAL_ASF_REQUESTOR_SEX"]
    ],
    "trigger_layoutconditions" : [
        ["# checked in sequence shown, first match determines layout selection"],
		["event"],
        ["1", "triggerlayout_asf"]
    ],
    "triggerlayout_asf" : [
        ["event", "chance"],
        ["asf_response", "asf_consensual"],
        ["asf_potential_orgy", "asf_sex"],
        ["", "daytime"],
        ["deeplocation", "is_weapon_drawn"],
        ["is_armed", "is_clothed"],
        ["do_1", "do_2"],
        ["do_3", "do_4"]
    ],
    "triggerlayout" : [
        ["event"]
    ]


    ,



    "settings_attributes" : [
        ["cards_per_page",      "settingsattribute_cards_per_page"]
    ],
    "settingsattribute_cards_per_page" : [
        ["type", "int"],
        ["widget", "menu", "$SLT_LBL_CORE_TRIGGERS_PER_PAGE", "4", "1", "2", "3", "4", "5"],
        ["info", "$SLT_INFO_CORE_TRIGGERS_PER_PAGE"]
    ],
	"settingslayout" : [
		["cards_per_page"]
	]
}