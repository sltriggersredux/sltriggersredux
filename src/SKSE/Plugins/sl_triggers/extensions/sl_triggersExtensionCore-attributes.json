    "triggerattribute_armor_slot" : [
        ["type", "int"],
        ["widget", "menu", "$SLT_LBL_CORE_ARMOR_SLOT", "0", "$SLT_OPT_ANY", "$SLT_OPT_BODY_HEAD_HANDS_FEET", "$SLT_OPT_RING_AMULET_CIRCLET", "$SLT_OPT_30_HEAD", "$SLT_OPT_31_HAIR", "$SLT_OPT_32_BODY", "$SLT_OPT_33_HANDS", "$SLT_OPT_34_FOREARM", "$SLT_OPT_35_AMULET", "$SLT_OPT_36_RING", "$SLT_OPT_37_FEET", "$SLT_OPT_38_CALVES", "$SLT_OPT_39_SHIELD", "$SLT_OPT_40_TAIL", "$SLT_OPT_41_LONG_HAIR", "$SLT_OPT_42_CIRCLET", "$SLT_OPT_43_EARS", "$SLT_OPT_44_UNNAMED", "$SLT_OPT_45_UNNAMED", "$SLT_OPT_46_UNNAMED", "$SLT_OPT_47_UNNAMED", "$SLT_OPT_48_UNNAMED", "$SLT_OPT_49_UNNAMED", "$SLT_OPT_50_DECAPITATE_HEAD", "$SLT_OPT_51_DECAPITATE", "$SLT_OPT_52_UNNAMED", "$SLT_OPT_53_UNNAMED", "$SLT_OPT_54_UNNAMED", "$SLT_OPT_55_UNNAMED", "$SLT_OPT_56_UNNAMED", "$SLT_OPT_57_UNNAMED", "$SLT_OPT_58_UNNAMED", "$SLT_OPT_59_UNNAMED", "$SLT_OPT_60_UNNAMED", "$SLT_OPT_61_FX01"],
